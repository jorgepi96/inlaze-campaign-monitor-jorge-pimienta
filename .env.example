# ==============================================================
# Inlaze Campaign Monitor — Variables de entorno
# ==============================================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore — nunca lo subas al repo.
#
#   cp .env.example .env
# ==============================================================

# ── Parte 4 — Integración LLM ─────────────────────────────────
# Obligatoria para que generateCampaignSummary() llame al LLM.
# Obtén tu clave en: https://platform.openai.com/api-keys
# Sin esta clave el sistema igualmente funciona; el LLM devuelve
# un LLMSummary con error flag en lugar de romper el flujo.
OPENAI_API_KEY=

# ── Parte 2 — Webhook N8N ─────────────────────────────────────
# URL del webhook de N8N al que se envía el ProcessResult como POST.
# Se obtiene desde el nodo "Webhook" de tu flujo en N8N (modo Test o Production).
# Sin esta variable el envío se omite sin romper el flujo.
N8N_WEBHOOK_URL=
